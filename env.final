# Discord Bot Token (Required)
# احصل عليه من: https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# Text Channel ID (Required)
# اعمل كليك يمين على الـ text channel واختار "Copy Channel ID"
CHANNEL_ID=1234567890123456789

# Server ID (Required for voice channel links)
# اعمل كليك يمين على اسم السيرفر واختار "Copy Server ID"
SERVER_ID=1234567890123456789

# ملحوظة: الـ Voice Channel IDs هتحطهم في main.py مباشرة في الـ schedule
